+
+### OpenGL ES зү№е®ҡзәҰе®ҡ
+
+- зқҖиүІеҷЁд»Јз Ғж”ҫеңЁ `res/raw/` зӣ®еҪ•
+- дҪҝз”Ёе·Ҙе…·зұ»е°ҒиЈ… OpenGL ж“ҚдҪң
+- жЈҖжҹҘжүҖжңү GL ж“ҚдҪңзҡ„й”ҷиҜҜ
+
+```kotlin
+object GLUtils {
+    fun loadShader(type: Int, shaderCode: String): Int {
+        val shader = GLES20.glCreateShader(type)
+        GLES20.glShaderSource(shader, shaderCode)
+        GLES20.glCompileShader(shader)
+        return shader
+    }
+    
+    fun checkGLError(tag: String) {
+        val error = GLES20.glGetError()
+        if (error != GLES20.GL_NO_ERROR) {
+            Log.e(tag, "OpenGL Error: $error")
+        }
+    }
+}
+```
+
+### й”ҷиҜҜеӨ„зҗҶ
+
+- дҪҝз”Ё `Result<T>` иҝӣиЎҢеҸҜиғҪеӨұиҙҘзҡ„ж“ҚдҪң
+- OpenGL й”ҷиҜҜйңҖиҰҒз«ӢеҚіжЈҖжҹҘ
+- ж—Ҙеҝ—дҪҝз”Ё `Log` зұ»пјҢж ҮзӯҫдҪҝз”ЁеёёйҮҸ
+
+```kotlin
+fun createProgram(vertexShader: Int, fragmentShader: Int): Result<Int> {
+    val program = GLES20.glCreateProgram()
+    if (program == 0) {
+        return Result.failure(GLException("Failed to create program"))
+    }
+    GLES20.glAttachShader(program, vertexShader)
+    GLES20.glAttachShader(program, fragmentShader)
+    GLES20.glLinkProgram(program)
+    return Result.success(program)
+}
+```
